# ============================================================
# 多智能体并行任务系统 - 环境变量配置示例
# ============================================================
# 作者：小码 🟡
# 日期：2026-03-16
# 
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改配置值
#   3. 确保数据库已启动
# ============================================================

# ============================================================
# 数据库配置
# ============================================================

# 方式一：直接使用连接字符串（推荐）
DATABASE_URL=postgresql://memory_user:memory_pass_2026@localhost:5432/memory_hub

# 方式二：分别配置各个参数（如果不使用 DATABASE_URL）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=memory_hub
# DB_USER=memory_user
# DB_PASSWORD=memory_pass_2026

# ============================================================
# 连接池配置
# ============================================================

# 最小连接数
DB_POOL_MIN=5

# 最大连接数
DB_POOL_MAX=20

# ============================================================
# 任务默认配置
# ============================================================

# 默认锁持续时间（分钟）
DEFAULT_LOCK_DURATION=30

# 默认任务超时时间（分钟）
DEFAULT_TIMEOUT=30

# 默认最大重试次数
DEFAULT_MAX_RETRIES=3

# ============================================================
# 日志配置
# ============================================================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否输出到文件
LOG_TO_FILE=false

# 日志文件路径
# LOG_FILE_PATH=logs/task_service.log