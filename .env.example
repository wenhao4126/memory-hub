# ============================================================
# 多智能体记忆中枢 - 环境变量配置
# ============================================================
# 使用方法：复制此文件为 .env 并修改配置
# 命令：cp .env.example .env
# ============================================================

# ============================================================
# 数据库配置
# ============================================================
DB_USER=memory_user
DB_PASSWORD=wf.8286253
DB_NAME=memory_hub
DB_PORT=5432

# ============================================================
# API 配置
# ============================================================
API_PORT=8000
API_DEBUG=false

# ============================================================
# 嵌入模型配置
# ============================================================
# 使用本地模型 bge-small-zh-v1.5（中文优化）
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# ============================================================
# 安全配置
# ============================================================
# CORS 允许的来源（多个用逗号分隔）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================
# 管理界面配置 (pgAdmin)
# ============================================================
ADMIN_EMAIL=admin@memory.hub
ADMIN_PASSWORD=wf.8286253
ADMIN_PORT=5050

# ============================================================
# 生产环境注意事项
# ============================================================
# ⚠️ 部署到生产环境前，请修改以下配置：
# 1. DB_PASSWORD - 使用强密码
# 2. ADMIN_PASSWORD - 使用强密码
# 3. API_DEBUG - 设置为 false
# 4. 配置防火墙，限制端口访问
