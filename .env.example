# ============================================================
# Memory Hub - 环境变量配置示例
# ============================================================
# 作者：小码 4 🟡
# 日期：2026-03-19
# 
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改配置值
#   3. 确保数据库已启动
# ============================================================

# ============================================================
# 🌐 服务器配置
# ============================================================

# 服务器监听主机
# 0.0.0.0 表示监听所有网络接口
# 127.0.0.1 表示仅本地访问
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# 工作模式：development | production
SERVER_MODE=development

# ============================================================
# 🗄️ 数据库配置
# ============================================================

# 方式一：直接使用连接字符串（推荐）
DATABASE_URL=postgresql://memory_user:memory_pass_2026@localhost:5432/memory_hub

# 方式二：分别配置各个参数（如果不使用 DATABASE_URL）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=memory_hub
# DB_USER=memory_user
# DB_PASSWORD=memory_pass_2026

# ============================================================
# 🔗 连接池配置
# ============================================================

# 最小连接数
DB_POOL_MIN=5

# 最大连接数
DB_POOL_MAX=20

# 连接空闲超时（毫秒）
DB_POOL_IDLE_TIMEOUT=30000

# 连接获取超时（毫秒）
DB_POOL_ACQUIRE_TIMEOUT=30000

# ============================================================
# 🧠 向量搜索配置
# ============================================================

# 向量维度（必须与 embedding 模型匹配）
# OpenAI text-embedding-ada-002: 1536
# DashScope text-embedding-v2: 1536
VECTOR_DIMENSIONS=1536

# 默认搜索匹配数量
VECTOR_DEFAULT_MATCH_COUNT=5

# 相似度阈值（0-1，越低越宽松）
VECTOR_SIMILARITY_THRESHOLD=0.7

# ============================================================
# 🤖 任务默认配置
# ============================================================

# 默认锁持续时间（分钟）
# 任务被锁定后，其他智能体无法领取
DEFAULT_LOCK_DURATION=30

# 默认任务超时时间（分钟）
# 超时后任务会被重新释放
DEFAULT_TIMEOUT=30

# 默认最大重试次数
DEFAULT_MAX_RETRIES=3

# ============================================================
# 🔐 安全配置
# ============================================================

# API 密钥（生产环境必须修改）
# 用于保护 API 端点
MEMORY_HUB_API_KEY=your_secret_api_key_here

# DashScope API 密钥（用于自动记忆提取）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# JWT 密钥（用于 Token 生成）
JWT_SECRET=your_jwt_secret_key_here

# ============================================================
# 🌍 CORS 配置
# ============================================================

# 允许的源（多个用逗号分隔）
# 生产环境请修改为实际域名
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# 是否允许凭证
CORS_ALLOW_CREDENTIALS=true

# ============================================================
# 📝 日志配置
# ============================================================

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 是否输出到文件
LOG_TO_FILE=false

# 日志文件路径
# LOG_FILE_PATH=logs/memory-hub.log

# 日志格式：text | json
LOG_FORMAT=text

# 是否彩色输出（开发环境）
LOG_COLORIZE=true

# ============================================================
# 📊 监控配置
# ============================================================

# 是否启用健康检查
HEALTH_CHECK_ENABLED=true

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# 是否启用指标收集
METRICS_ENABLED=false

# 指标端口
METRICS_PORT=9090

# ============================================================
# ⚡ 性能优化配置
# ============================================================

# 是否启用缓存
CACHE_ENABLED=true

# 缓存类型：memory | redis
CACHE_TYPE=memory

# 缓存 TTL（秒）
CACHE_TTL=300

# Redis 连接字符串（当 CACHE_TYPE=redis 时使用）
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# 🤖 自动记忆提取配置
# ============================================================

# 是否启用自动提取
MEMORY_EXTRACTION_ENABLED=true

# 提取器类型：simple | llm
MEMORY_EXTRACTOR_TYPE=simple

# LLM 提供商：dashscope | openai
LLM_PROVIDER=dashscope

# LLM 模型
LLM_MODEL=qwen-plus

# ============================================================
# 📦 批量操作配置
# ============================================================

# 最大批量大小
BATCH_MAX_SIZE=100

# 批量超时（毫秒）
BATCH_TIMEOUT=1000

# ============================================================
# 🔔 通知配置（可选）
# ============================================================

# 飞书 Webhook URL（任务通知）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 邮件通知（SMTP 配置）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=memory-hub@example.com

# ============================================================
# 🐳 Docker 特定配置（仅 Docker 环境使用）
# ============================================================

# pgAdmin 配置
ADMIN_EMAIL=admin@memory.hub
ADMIN_PASSWORD=your_pgadmin_password_here

# 数据库备份配置
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨 2 点

# ============================================================
# 🎯 其他配置
# ============================================================

# 时区
TZ=Asia/Shanghai

# 字符编码
PYTHONIOENCODING=utf-8

# 调试模式（启用后显示详细错误信息）
DEBUG=false

# 是否启用 Swagger UI
SWAGGER_UI_ENABLED=true

# API 文档路径
API_DOCS_PATH=/docs

# ============================================================
# 结束
# ============================================================
# 提示：生产环境请使用强密码，并妥善保管此文件！
# 不要将 .env 文件提交到版本控制系统！
