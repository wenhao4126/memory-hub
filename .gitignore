# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
ENV/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# 日志
*.log
logs/

# 数据库数据（Docker 卷）
postgres_data/
pgadmin_data/

# 本地数据库文件（包含敏感数据）
*.db
*.sqlite
*.sqlite3
data/
*.data

# API 密钥和配置文件
config/*.json
!config/.gitkeep

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/

# macOS
.DS_Store

# 临时文件
tmp/
temp/
*.tmp